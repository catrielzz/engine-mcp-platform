{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://engine-mcp-platform.local/contracts/capabilities/test.job.read.output.schema.json",
  "title": "test.job.read output",
  "$defs": {
    "summary": {
      "type": "object",
      "required": ["passed", "failed", "skipped"],
      "properties": {
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "type": "object",
  "required": ["jobId", "status", "summary", "results"],
  "properties": {
    "jobId": {
      "$ref": "https://engine-mcp-platform.local/contracts/schemas/common.schema.json#/$defs/nonEmptyString"
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "failed", "canceled"]
    },
    "progress": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "https://engine-mcp-platform.local/contracts/schemas/common.schema.json#/$defs/testCaseResult"
      }
    }
  },
  "additionalProperties": false
}
