{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://engine-mcp-platform.local/contracts/capabilities/asset.search.input.schema.json",
  "title": "asset.search input",
  "type": "object",
  "properties": {
    "query": {
      "$ref": "https://engine-mcp-platform.local/contracts/schemas/common.schema.json#/$defs/nonEmptyString"
    },
    "roots": {
      "$ref": "https://engine-mcp-platform.local/contracts/schemas/common.schema.json#/$defs/stringList"
    },
    "kinds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["scene", "prefab", "script", "material", "texture", "shader", "other"]
      }
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 200
    }
  },
  "anyOf": [
    {
      "required": ["query"],
      "properties": {
        "query": {
          "$ref": "https://engine-mcp-platform.local/contracts/schemas/common.schema.json#/$defs/nonEmptyString"
        }
      }
    },
    {
      "required": ["roots"],
      "properties": {
        "roots": {
          "$ref": "https://engine-mcp-platform.local/contracts/schemas/common.schema.json#/$defs/stringList"
        }
      }
    },
    {
      "required": ["kinds"],
      "properties": {
        "kinds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["scene", "prefab", "script", "material", "texture", "shader", "other"]
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
