{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://engine-mcp-platform.local/contracts/capabilities/console.read.input.schema.json",
  "title": "console.read input",
  "type": "object",
  "properties": {
    "sinceSequence": {
      "type": "integer",
      "minimum": 0
    },
    "severities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["info", "warning", "error"]
      }
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 500
    }
  },
  "additionalProperties": false
}
